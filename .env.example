# hermes-console 本地环境变量模板
#
# 说明：当前应用未引入 dotenv 运行时依赖，以下变量用于：
#   1) 本地覆盖 / 文档示例
#   2) 通过 `flutter build --dart-define=KEY=VALUE` 注入构建时常量
#
# 用法示例：
#   flutter build apk --release --dart-define=HERMES_LOG_LEVEL=debug
#
# 复制本文件为 .env 并按需修改（.env 已被 .gitignore 忽略）。

# 服务地址
HERMES_API_BASE_URL=https://api.example.com
HERMES_GATEWAY_WS=wss://gateway.example.com

# 日志级别: debug | info | warn | error
HERMES_LOG_LEVEL=info

# 是否启用调试面板
HERMES_DEBUG_UI=false
